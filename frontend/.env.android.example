# Copy to .env.android before running `npm run build:android`. The Android app
# has no same-origin backend to make relative /api requests against (unlike the
# website), so it needs an absolute address.
#
# VITE_DISCOVERY_URL is the permanent Cloudflare Worker that reports where the
# backend currently lives. The app asks it at startup, so a rotating tunnel URL
# never requires rebuilding/reinstalling the app. Deploy it from ../worker.
VITE_DISCOVERY_URL=https://eg-music.<your-subdomain>.workers.dev/config

# Optional fallback for a first-ever launch if the Worker is unreachable.
# After one successful discovery the app remembers the address itself.
VITE_API_URL=https://your-current-tunnel-url.trycloudflare.com
