# Copy to .env.android and set the backend's current public URL before
# running `npm run build:android`. Needed because the Android app has no
# same-origin backend to make relative /api requests against (unlike the
# website). Whenever the Cloudflare tunnel restarts and rotates its address
# (see ../tunnel.log), this file must be updated and the app rebuilt.
VITE_API_URL=https://your-current-tunnel-url.trycloudflare.com
