# ─────────── Python (backend) ───────────
venv/
.venv/
__pycache__/
*.py[cod]
*.egg-info/

# ─────────── Database (SQLite runtime data) ───────────
*.db
*.db-shm
*.db-wal
*.sqlite3

# ─────────── User uploads (runtime data) ───────────
# Keep the folder structure, ignore the uploaded files themselves.
backend/uploads/*/*
!backend/uploads/*/.gitkeep

# ─────────── Node / Vite (frontend) ───────────
node_modules/
frontend/dist/
*.local

# ─────────── Secrets / environment ───────────
.env
.env.local
.env.*.local
backend/secret_key.txt

# ─────────── Editor / OS cruft ───────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log
