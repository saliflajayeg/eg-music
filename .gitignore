# ─────────── Python (backend) ───────────
venv/
.venv/
__pycache__/
*.py[cod]
*.egg-info/

# ─────────── Database (SQLite runtime data) ───────────
*.db
*.db-shm
*.db-wal
*.sqlite3

# ─────────── User uploads (runtime data) ───────────
# Keep the folder structure, ignore the uploaded files themselves.
backend/uploads/*/*
!backend/uploads/*/.gitkeep

# ─────────── Node / Vite (frontend) ───────────
node_modules/
frontend/dist/
*.local

# ─────────── Secrets / environment ───────────
.env
.env.local
.env.*.local
backend/secret_key.txt
frontend/.env.android

# ─────────── Android (Capacitor native project) ───────────
# The android/ project itself IS committed (Capacitor convention) — only
# machine-specific build output and local SDK path are ignored.
frontend/android/**/build/
frontend/android/.gradle/
frontend/android/local.properties
frontend/android/app/release/
*.apk
*.aab
*.keystore
*.jks

# ─────────── Editor / OS cruft ───────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log
