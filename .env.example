# Copy this file to `.env` and set your own value before deploying.
#
# SECRET_KEY signs the JWT authentication tokens (see backend/auth.py).
# Use a long, random string. Anyone who knows it can forge logins.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-secret
